{
  "version": 1,
  "name": "operator-black",
  "shared": {
    "--hf-ui-font-sans": "ui-sans-serif, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
    "--hf-ui-font-mono": "ui-monospace, \"SFMono-Regular\", Menlo, Consolas, monospace",
    "--hf-ui-weight-regular": "400",
    "--hf-ui-weight-medium": "500",
    "--hf-ui-weight-semibold": "600",
    "--hf-ui-radius-control": "5px",
    "--hf-ui-radius-surface": "7px",
    "--hf-ui-radius-overlay": "10px",
    "--hf-ui-control-height": "40px",
    "--hf-ui-hit-target": "44px",
    "--hf-ui-space-1": "4px",
    "--hf-ui-space-2": "8px",
    "--hf-ui-space-3": "12px",
    "--hf-ui-space-4": "16px",
    "--hf-ui-space-6": "24px",
    "--hf-ui-space-8": "32px",
    "--hf-ui-space-12": "48px",
    "--hf-ui-space-16": "64px",
    "--hf-ui-duration-press": "120ms",
    "--hf-ui-duration-state": "160ms",
    "--hf-ui-duration-overlay-enter": "210ms",
