  "themes": {
    "dark": {
      "--hf-ui-canvas": "#0a0a0a",
      "--hf-ui-surface": "#141414",
      "--hf-ui-surface-raised": "#1a1a1a",
      "--hf-ui-surface-inset": "#101010",
      "--hf-ui-border": "#2a2a2a",
      "--hf-ui-border-strong": "#383838",
      "--hf-ui-control-border": "#686868",
      "--hf-ui-control-border-hover": "#777777",
      "--hf-ui-text": "#e5e5e5",
      "--hf-ui-text-strong": "#f3f3f3",
      "--hf-ui-text-muted": "#929292",
      "--hf-ui-text-faint": "#7e7e7e",
      "--hf-ui-accent": "#3ce6ac",
      "--hf-ui-danger": "#ff7878",
      "--hf-ui-warning": "#e9ab55",
      "--hf-ui-action": "#eeeeee",
      "--hf-ui-action-contrast": "#111111",
      "--hf-ui-data-1": "#3ce6ac",
      "--hf-ui-data-2": "#63a5ff",
      "--hf-ui-data-3": "#e9ab55",
      "--hf-ui-data-4": "#a78bfa",
      "--hf-ui-data-5": "#ff8a75",
      "--hf-ui-shadow-inset": "inset 0 1px 0 rgba(255, 255, 255, 0.035)",
      "--hf-ui-shadow-contact": "0 8px 18px rgba(0, 0, 0, 0.38)",
      "--hf-ui-shadow-modal": "0 18px 46px rgba(0, 0, 0, 0.52)"
    },
    "light": {
      "--hf-ui-canvas": "#f6f5f1",
      "--hf-ui-surface": "#ffffff",
      "--hf-ui-surface-raised": "#ffffff",
      "--hf-ui-surface-inset": "#f0efeb",
      "--hf-ui-border": "#e0dfdb",
      "--hf-ui-border-strong": "#cbc9c3",
      "--hf-ui-control-border": "#888888",
      "--hf-ui-control-border-hover": "#6f6e68",
      "--hf-ui-text": "#171717",
      "--hf-ui-text-strong": "#0a0a0a",
      "--hf-ui-text-muted": "#5f5f5a",
      "--hf-ui-text-faint": "#6f6e68",
      "--hf-ui-accent": "#087a57",
      "--hf-ui-danger": "#a61b1b",
      "--hf-ui-warning": "#8a4b00",
      "--hf-ui-action": "#171717",
      "--hf-ui-action-contrast": "#ffffff",
      "--hf-ui-data-1": "#087a57",
      "--hf-ui-data-2": "#245ea8",
      "--hf-ui-data-3": "#8a4b00",
      "--hf-ui-data-4": "#6d3fc0",
      "--hf-ui-data-5": "#a83d2d",
      "--hf-ui-shadow-inset": "inset 0 1px 0 rgba(255, 255, 255, 0.78)",
      "--hf-ui-shadow-contact": "0 7px 16px rgba(26, 24, 20, 0.13)",
      "--hf-ui-shadow-modal": "0 18px 46px rgba(26, 24, 20, 0.18)"
    }
  }
}
