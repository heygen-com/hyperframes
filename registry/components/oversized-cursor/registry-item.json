      "max": 85,
      "step": 1,
      "unit": "%"
    },
    {
      "id": "target_y",
      "type": "number",
      "role": "layout",
      "label": "Target Y",
      "default": 55,
      "min": 15,
      "max": 85,
      "step": 1,
      "unit": "%"
    },
    {
      "id": "click_label",
      "type": "string",
      "role": "content",
      "label": "Click label",
      "default": "Generate"
    }
  ]
